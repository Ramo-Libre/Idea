---
import { Menu, Plus, User, Download, FileText, LayoutDashboard } from '@lucide/astro';

const typeIcon = {
	note: FileText,
	board: LayoutDashboard,
} as const;

const dummyFiles = [
	{ id: '1', name: 'Apuntes iniciales', type: 'note' as const },
	{ id: '2', name: 'Referencias', type: 'note' as const },
	{ id: '3', name: 'Diagrama de flujo', type: 'board' as const },
	{ id: '4', name: 'Mapa conceptual', type: 'board' as const },
];
---

<div
	class="grid h-dvh overflow-hidden"
	style="grid-template-rows: 40px 1fr 24px; grid-template-columns: 200px 1fr"
>
	<!-- ═══ TOP BAR ═══ -->
	<header
		class="border-base-400 bg-base-100 col-span-2 flex items-center justify-between border-b px-3"
	>
		<div class="flex items-center gap-2">
			<button
				class="text-content/40 hover:bg-base-200 hover:text-content flex cursor-pointer items-center justify-center rounded-md p-1.5"
			>
				<Menu size={16} />
			</button>
			<span class="text-content text-sm font-medium">Mi Idea</span>
		</div>

		<div class="flex items-center gap-2">
			<button
				class="text-content/40 hover:bg-base-200 hover:text-content flex cursor-pointer items-center justify-center rounded-md p-1.5"
			>
				<User size={15} />
			</button>
			<button
				class="text-content/40 hover:bg-base-200 hover:text-content flex cursor-pointer items-center justify-center rounded-md p-1.5"
			>
				<Download size={15} />
			</button>
		</div>
	</header>

	<!-- ═══ SIDEBAR ═══ -->
	<aside class="border-base-400 bg-base-100 flex flex-col overflow-y-auto border-r">
		<div class="border-base-400 flex gap-2 border-b px-3 py-2.5">
			<button
				class="bg-base-200 text-content/60 hover:bg-base-300 hover:text-content flex cursor-pointer flex-1 items-center justify-center gap-1 rounded-md py-1.5 text-xs font-medium"
			>
				<Plus size={13} />
				Nota
			</button>
			<button
				class="bg-base-200 text-content/60 hover:bg-base-300 hover:text-content flex cursor-pointer flex-1 items-center justify-center gap-1 rounded-md py-1.5 text-xs font-medium"
			>
				<Plus size={13} />
				Board
			</button>
		</div>

		<div class="flex-1 space-y-px px-3 pt-3">
			{dummyFiles.map((file) => {
				const Icon = typeIcon[file.type];
				return (
					<button class="text-content/70 hover:bg-base-200 flex w-full cursor-pointer items-center gap-2 rounded-md px-2 py-1.5 text-left text-sm">
						<Icon size={15} class="shrink-0 text-content/40" />
						{file.name}
					</button>
				);
			})}
		</div>
	</aside>

	<!-- ═══ MAIN ═══ -->
	<main class="bg-base-200 overflow-y-auto">
		<slot />
	</main>

	<!-- ═══ STATUS BAR ═══ -->
	<footer class="border-base-400 bg-base-100 col-span-2 flex items-center border-t px-4">
		<span class="text-content/30 text-[11px]">local · sin cambios · 3 notas, 1 board</span>
	</footer>
</div>
